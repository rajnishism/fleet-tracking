generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id        String     @id @default(cuid())
  vehicleId String     @unique
  name      String?
  power     Float?     // Engine power in kW
  vMax      Float?     // Maximum speed in km/h
  createdAt DateTime   @default(now())
  locations Location[]
  alerts    Alert[]
}

model Location {
  id              Int      @id @default(autoincrement())
  vehicleId       String
  latitude        Float
  longitude       Float
  elevation       Float    @default(0)
  speedKmh        Float
  timestamp       String
  distFromRouteM  Float    @default(0)
  distanceStepM   Float    @default(0)
  fuelConsumedLiters Float @default(0)
  createdAt       DateTime @default(now())
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [vehicleId])

  @@index([vehicleId])
}

model Alert {
  id        Int      @id @default(autoincrement())
  vehicleId String
  type      String   // ROUTE_DEVIATION | IDLE | FUEL_ANOMALY
  message   String
  metadata  String   // JSON string of extra fields
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [vehicleId])

  @@index([vehicleId])
  @@index([type])
}
